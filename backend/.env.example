# DataAtlas Server Configuration
PORT=5000

# Databricks Connections (Optional - leave blank to use Simulation Mode)
# Example Host: https://dbc-12345678-abcd.cloud.databricks.com
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# Databricks SQL Warehouse HTTP Path (Optional - used for Delta history and data previews)
# Example Path: /sql/1.0/warehouses/1234567890abcdef
DATABRICKS_SQL_HTTP_PATH=
